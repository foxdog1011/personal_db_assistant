{
  "compilerOptions": {
    /* =============================
     🧠 基本設定
    ============================= */
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* =============================
     ⚙️ 輸出設定
    ============================= */
    "rootDir": "./electron",
    "outDir": "./dist-electron",
    "resolveJsonModule": true,
    "sourceMap": true,
    "noEmitOnError": false,

    /* =============================
     📦 型別定義
    ============================= */
    "types": ["node", "electron"]
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["node_modules"]
}
